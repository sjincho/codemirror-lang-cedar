{
  "name": "@ridi/codemirror-lang-cedar",
  "version": "0.1.0",
  "description": "Cedar policy language support for CodeMirror 6",
  "keywords": [
    "codemirror",
    "cedar",
    "language",
    "policy",
    "syntax-highlighting"
  ],
  "license": "MIT",
  "repository": "github:ridi-oss/codemirror-lang-cedar",
  "homepage": "https://github.com/ridi-oss/codemirror-lang-cedar#readme",
  "bugs": "https://github.com/ridi-oss/codemirror-lang-cedar/issues",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.js.map",
    "dist/index.cjs",
    "dist/index.cjs.map",
    "dist/*.d.ts",
    "dist/*.d.ts.map",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c",
    "test": "mocha \"test/**/*.test.js\"",
    "demo:build": "rollup -c rollup.demo.config.mjs"
  },
  "dependencies": {
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10"
  },
  "peerDependencies": {
    "@cedar-policy/cedar-wasm": "^4.11.2",
    "@codemirror/autocomplete": "^6.0.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/language": "^6.0.0",
    "@codemirror/lint": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "@cedar-policy/cedar-wasm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cedar-policy/cedar-wasm": "^4.11.2",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@lezer/generator": "^1.8.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.1.0",
    "jsdom": "^29.1.1",
    "mocha": "^11.7.6",
    "rollup": "^4.62.2",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  }
}
